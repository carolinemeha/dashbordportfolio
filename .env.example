NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_EMAIL=admin@exemple.com
ADMIN_PASSWORD=
JWT_SECRET=
NEXTAUTH_SECRET=

POSTAL_API_URL=https://sender.exemple.com
POSTAL_API_KEY=
POSTAL_SERVER_API_KEY=

CONTACT_RECIPIENT=admin@exemple.com
CONTACT_FROM=noreply@exemple.com
MAIL_TO_ADMIN=admin@exemple.com
MAIL_FROM="Portfolio <noreply@exemple.com>"

VITE_CONTACT_API_URL=http://localhost:3040

# URL du site vitrine (liens portail client depuis le CRM)
